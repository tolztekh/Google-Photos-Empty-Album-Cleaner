{
  "manifest_version": 3,
  "name": "Sinemarka Google Photos Empty Album Cleaner",
  "version": "1.0.0",
  "description": "Preview and bulk-delete empty Google Photos albums from your signed-in browser session.",
  "author": "Sinemarka",
  "homepage_url": "https://dev.sinemarka.com",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": ["https://photos.google.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Sinemarka Google Photos Empty Album Cleaner",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/albums*"],
      "js": ["page.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://photos.google.com/albums*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
